# METU Gym Management System — Web imajı: Vite build + Nginx (SRS 8.5)
# Nginx hem SPA'yı sunar hem /api'yi API konteynerine yönlendirir
# hem de /media altındaki videoları statik (HTTP range destekli) yayınlar.

FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY index.html vite.config.js tailwind.config.js postcss.config.js ./
COPY src ./src
RUN npm run build

FROM nginx:1.27-alpine
COPY nginx/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
