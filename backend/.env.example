# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/metugym?schema=public"

PORT=3000
CORS_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173

# Rastgele uzun değerler üretin (ör. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES=30m
JWT_REFRESH_EXPIRES=7d

SLOT_DURATION_MINUTES=30
SLOT_CAPACITY=10
GYM_OPEN_HOUR=8
GYM_CLOSE_HOUR=22
BOOKING_WINDOW_DAYS=14

# Randevu hatırlatma bildirimi: randevudan kaç dakika önce üretilsin (varsayılan 2 saat).
REMINDER_LEAD_MINUTES=120

# Parola sıfırlama e-postası (NFR-6: ücretsiz SMTP — örn. https://ethereal.email
# test kutusu ya da Gmail uygulama şifresi). Boş bırakılırsa e-posta gönderilmez;
# sıfırlama bağlantısı sunucu loguna yazılır (yalnızca geliştirme için).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=METU Gym <no-reply@metugym.local>

MUSCLEWIKI_API_KEY=
