# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/metugym?schema=public"

PORT=3000
CORS_ORIGIN=http://localhost:5173

# Rastgele uzun değerler üretin (ör. openssl rand -hex 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

SLOT_DURATION_MINUTES=30
SLOT_CAPACITY=10
